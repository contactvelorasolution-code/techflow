# ============================================================
#  TECHFLOW POS — Variables d'environnement
#  Copier ce fichier en .env pour le développement local
#  Sur Render : ajouter ces variables dans "Environment"
# ============================================================

# PostgreSQL Supabase
# Trouver dans : Supabase > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.[REF].supabase.co:5432/postgres

# Session secret (chaîne aléatoire longue)
SESSION_SECRET=remplacer_par_une_longue_chaine_aleatoire_secrete

# Supabase API
# Trouver dans : Supabase > Settings > API
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...votre_service_role_key...

# Nom du bucket Supabase Storage (créer un bucket public avec ce nom)
SUPABASE_BUCKET=uploads

# Environnement (mettre "production" sur Render)
NODE_ENV=production
